{
  "name": "@xepha/cli",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "license": "MIT",
  "bin": {
    "xepha": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "lint": "eslint . --max-warnings 0",
    "check-types": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@xepha/core": "workspace:*",
    "commander": "^14.0.2"
  },
  "devDependencies": {
    "@xepha/eslint-config": "workspace:*",
    "@xepha/typescript-config": "workspace:*",
    "@types/node": "^22.15.3",
    "eslint": "^9.39.1",
    "tsx": "^4.21.0",
    "typescript": "5.9.2",
    "vitest": "^4.0.15"
  }
}
